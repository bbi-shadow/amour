rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ── USERS ─────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      // Cho phép tạo/cập nhật nếu UID khớp với người đang đăng nhập
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // ── MATCHES ───────────────────────────────
    match /matches/{matchId} {
      // Cho phép đọc nếu là 1 trong 2 người trong match
      allow read: if isSignedIn() && request.auth.uid in resource.data.users;
      allow write: if isSignedIn();
    }

    // ── CONVERSATIONS ─────────────────────────
    match /conversations/{convId} {
      // Cho phép đọc/ghi nếu là thành viên cuộc hội thoại hoặc đang tạo mới
      allow read, write: if isSignedIn() && (
        resource == null || request.auth.uid in resource.data.participants
      );

      match /messages/{msgId} {
        allow read, write: if isSignedIn();
      }
    }

    // ── INTERATIONS ──────────────────────────
    match /swipes/{userId}/actions/{targetId} { allow read, write: if isOwner(userId); }
    match /likes/{userId}/liked/{targetId} { allow read, write: if isOwner(userId); }
    match /blocks/{userId}/blocked/{targetId} { allow read, write: if isOwner(userId); }

    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read: if false;
    }

    match /notifications/{notifId} {
      allow read, update: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn();
    }

    match /calls/{callId} {
      allow read, write: if isSignedIn();
    }

    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource == null || request.auth.uid == resource.data.authorId
      );
    }

    match /cities/{cityId} {
      allow read: if isSignedIn();
    }

    match /following/{userId}/list/{targetId} { allow read, write: if isOwner(userId); }
    match /followers/{userId}/list/{targetId} { allow read, write: if isSignedIn(); }
  }
}
